<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    tools:context="com.railbot.usrc.robotcontrol.ServerSettingsActivity">


    <LinearLayout
        android:layout_width="368dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="100dp"
        android:layout_marginLeft="20dp"
        tools:layout_editor_absoluteY="0dp"
        tools:layout_editor_absoluteX="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Server Address"
            android:textSize="20sp"
            android:textColor="#acffffff"/>
        <EditText
            android:id="@+id/ip_address"
            android:inputType="number|numberDecimal"
            android:digits="0123456789."
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:cursorVisible="true"
            android:textCursorDrawable="@color/blue"
            android:hint="IP Address"
            android:textColor="#acffffff"
            android:textSize="20sp"
            android:background="#80808080"
            android:layout_marginLeft="20dp"
            android:text="192.168.0.143"/>
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:layout_marginLeft="20dp"
        tools:layout_editor_absoluteY="0dp"
        tools:layout_editor_absoluteX="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VoIP Port"
            android:textSize="20sp"
            android:textColor="#acffffff"/>
        <EditText
            android:id="@+id/voip_port"
            android:inputType="number"
            android:digits="0123456789"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:cursorVisible="true"
            android:textCursorDrawable="@color/blue"
            android:textColor="#acffffff"
            android:textSize="20sp"
            android:background="#80808080"
            android:layout_marginLeft="20dp"
            android:text="1049"/>
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:layout_marginLeft="20dp"
        tools:layout_editor_absoluteY="0dp"
        tools:layout_editor_absoluteX="8dp">
        <Button
            android:id="@+id/set"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set"
            android:textSize="15sp"
            android:background="@drawable/button_set"
            android:textColor="#acffffff"/>
    </LinearLayout>

</LinearLayout>
